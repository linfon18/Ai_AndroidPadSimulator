<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="AndroidPadSimulator.App"
             xmlns:local="using:AndroidPadSimulator"
             xmlns:conv="using:AndroidPadSimulator.Converters"
             RequestedThemeVariant="Dark">

    <Application.DataTemplates>
        <local:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <conv:BoolToColorConverter x:Key="BoolToColorConverter"/>
        <conv:BoolToTextConverter x:Key="BoolToTextConverter"/>
        <conv:IntToBoolConverter x:Key="IntToBoolConverter"/>
        <conv:TabIndexToColorConverter x:Key="TabIndexToColorConverter"/>
        <conv:CallTypeToColorConverter x:Key="CallTypeToColorConverter"/>
        <conv:FirstCharConverter x:Key="FirstCharConverter"/>
    </Application.Resources>

    <Application.Styles>
        <FluentTheme />
    </Application.Styles>
</Application>
