                        </StackPanel>
                    </UniformGrid>
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <!-- 底部Dock栏 -->
        <Border VerticalAlignment="Bottom"
                Margin="40,0,40,20"
                Height="72"
                CornerRadius="24"
                Background="#20FFFFFF">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 电话 -->
                <Button Grid.Column="0" 
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding OpenPhoneCommand}">
                    <Path Data="M6.62,10.79 C8.06,13.62 10.38,15.94 13.21,17.38 L15.41,15.18 C15.69,14.9 16.08,14.82 16.43,14.93 C17.55,15.3 18.75,15.5 20,15.5 C20.55,15.5 21,15.95 21,16.5 L21,20 C21,20.55 20.55,21 20,21 C10.61,21 3,13.39 3,4 C3,3.45 3.45,3 4,3 L7.5,3 C8.05,3 8.5,3.45 8.5,4 C8.5,5.25 8.7,6.45 9.07,7.57 C9.18,7.92 9.1,8.31 8.82,8.59 L6.62,10.79 Z" Fill="White" Width="28" Height="28"/>
