<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AndroidPadSimulator.ViewModels"
             x:Class="AndroidPadSimulator.Views.HomeScreenView"
             x:DataType="vm:HomeScreenViewModel">

    <Grid x:Name="RootGrid">
        <!-- 壁纸背景 -->
        <Image Source="{Binding WallpaperSource}"
               Stretch="UniformToFill"
               Opacity="0.9"/>

        <!-- 渐变遮罩 -->
        <Rectangle>
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Offset="0" Color="#20000000"/>
                    <GradientStop Offset="0.7" Color="#10000000"/>
                    <GradientStop Offset="1" Color="#60000000"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- 顶部状态栏 - 添加下拉手势区域 -->
        <Border x:Name="StatusBarArea"
                VerticalAlignment="Top"
                Height="60"
                Background="Transparent"
                PointerPressed="OnStatusBarPressed"
                PointerMoved="OnStatusBarMoved"
                PointerReleased="OnStatusBarReleased">
            <Grid Margin="20,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 时间 -->
                <TextBlock Text="{Binding CurrentTime}"
                           Foreground="White"
                           FontSize="14"
                           FontWeight="Medium"/>

                <!-- 状态图标 -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="8">
                    <Path Data="M2,18 L6,18 L6,22 L2,22 Z M7,16 L11,16 L11,22 L7,22 Z M12,12 L16,12 L16,22 L12,22 Z M17,8 L21,8 L21,22 L17,22 Z"
                          Fill="White" Width="16" Height="16"/>
                    <Path Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 Z M12,20 C7.59,20 4,16.41 4,12 C4,7.59 7.59,4 12,4 C16.41,4 20,7.59 20,12 C20,16.41 16.41,20 12,20 Z M12,6 C9.79,6 8,7.79 8,10 L10,10 C10,8.9 10.9,8 12,8 C13.1,8 14,8.9 14,10 L16,10 C16,7.79 14.21,6 12,6 Z"
                          Fill="White" Width="16" Height="16"/>
                    <Path Data="M15.67,4 L14,4 L14,2 L10,2 L10,4 L8.33,4 C7.6,4 7,4.6 7,5.33 L7,20.67 C7,21.4 7.6,22 8.33,22 L15.67,22 C16.4,22 17,21.4 17,20.67 L17,5.33 C17,4.6 16.4,4 15.67,4 Z"
                          Fill="White" Width="16" Height="16"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 搜索栏 -->
        <Border VerticalAlignment="Top"
                Margin="60,50,60,0"
                Height="44"
                CornerRadius="22"
                Background="#30FFFFFF">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Path Grid.Column="0" Data="M15.5,14 L14.71,14 L14.43,13.73 C15.41,12.59 16,11.11 16,9.5 C16,5.91 13.09,3 9.5,3 C5.91,3 3,5.91 3,9.5 C3,13.09 5.91,16 9.5,16 C11.11,16 12.59,15.41 13.73,14.43 L14,14.71 L14,15.5 L19,20.49 L20.49,19 L15.5,14 Z M9.5,14 C7.01,14 5,11.99 5,9.5 C5,7.01 7.01,5 9.5,5 C11.99,5 14,7.01 14,9.5 C14,11.99 11.99,14 9.5,14 Z"
                      Fill="White" Width="20" Height="20" Margin="16,0,0,0"/>
                <TextBlock Grid.Column="1" Text="搜索应用、联系人、设置..." Foreground="#CCFFFFFF" FontSize="14" VerticalAlignment="Center" Margin="12,0"/>
                <Path Grid.Column="2" Data="M12,14 C13.66,14 14.99,12.66 14.99,11 L15,5 C15,3.34 13.66,2 12,2 C10.34,2 9,3.34 9,5 L9,11 C9,12.66 10.34,14 12,14 Z M17,11 C17,14.53 14.39,17.43 11,17.92 L11,21 L13,21 L13,23 L11,23 L11,24 L13,24 L13,26 L11,26 L11,28 L13,28 L13,30 L11,30 L11,32 L13,32 L13,34 L11,34 L11,36 L13,36 L13,38 L11,38 L11,40 L13,40 L13,42 L11,42 L11,44 L13,44 L13,46 L11,46 L11,48 L13,48 L13,50 L11,50 L11,52 L13,52 L13,54 L11,54 L11,56 L13,56 L13,58 L11,58 L11,60 L13,60 L13,62 L11,62 L11,64 L13,64 L13,66 L11,66 L11,68 L13,68 L13,70 L11,70 L11,72 L13,72 L13,74 L11,74 L11,76 L13,76 L13,78 L11,78 L11,80 L13,80 L13,82 L11,82 L11,84 L13,84 L13,86 L11,86 L11,88 L13,88 L13,90 L11,90 L11,92 L13,92 L13,94 L11,94 L11,96 L13,96 L13,98 L11,98 L11,100 L13,100"
                      Fill="White" Width="20" Height="20" Margin="0,0,16,0"/>
            </Grid>
        </Border>

        <!-- 应用网格 - 分页滑动 -->
        <ScrollViewer x:Name="AppPagesScrollViewer"
                      Margin="40,120,40,120"
                      HorizontalAlignment="Stretch"
                      VerticalAlignment="Stretch"
                      HorizontalScrollBarVisibility="Hidden"
                      VerticalScrollBarVisibility="Disabled"
                      AllowAutoHide="True">
            <StackPanel Orientation="Horizontal">
                <!-- 第1页 -->
                <Grid Width="{Binding $parent[ScrollViewer].Bounds.Width}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

            <!-- 第一行应用 -->
            <UniformGrid Grid.Row="0" Columns="5" Margin="0,20">
                <!-- 电话 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Button Width="56" 
                            Height="56" 
                            CornerRadius="16" 
                            Background="#4CAF50"
                            BorderThickness="0"
                            Command="{Binding OpenPhoneCommand}">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M6.62,10.79 C8.06,13.62 10.38,15.94 13.21,17.38 L15.41,15.18 C15.69,14.9 16.08,14.82 16.43,14.93 C17.55,15.3 18.75,15.5 20,15.5 C20.55,15.5 21,15.95 21,16.5 L21,20 C21,20.55 20.55,21 20,21 C10.61,21 3,13.39 3,4 C3,3.45 3.45,3 4,3 L7.5,3 C8.05,3 8.5,3.45 8.5,4 C8.5,5.25 8.7,6.45 9.07,7.57 C9.18,7.92 9.1,8.31 8.82,8.59 L6.62,10.79 Z" Fill="White"/>
                        </Viewbox>
                    </Button>
                    <TextBlock Text="电话" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- 信息 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Button Width="56" 
                            Height="56" 
                            CornerRadius="16" 
                            Background="#2196F3"
                            BorderThickness="0"
                            Command="{Binding OpenMessagesCommand}">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M20,2 L4,2 C2.9,2 2,2.9 2,4 L2,22 L6,18 L20,18 C21.1,18 22,17.1 22,16 L22,4 C22,2.9 21.1,2 20,2 Z M6,9 L18,9 L18,11 L6,11 L6,9 Z M14,14 L6,14 L6,12 L14,12 L14,14 Z M18,8 L6,8 L6,6 L18,6 L18,8 Z" Fill="White"/>
                        </Viewbox>
                    </Button>
                    <TextBlock Text="信息" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- Chrome -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Button Width="56" 
                            Height="56" 
                            CornerRadius="16" 
                            Background="#F44336"
                            BorderThickness="0"
                            Command="{Binding OpenChromeCommand}">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 Z M12,20 C7.59,20 4,16.41 4,12 C4,7.59 7.59,4 12,4 C16.41,4 20,7.59 20,12 C20,16.41 16.41,20 12,20 Z M12,6 C8.69,6 6,8.69 6,12 C6,15.31 8.69,18 12,18 C15.31,18 18,15.31 18,12 C18,8.69 15.31,6 12,6 Z" Fill="White"/>
                        </Viewbox>
                    </Button>
                    <TextBlock Text="Chrome" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- 相机 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="56" Height="56" CornerRadius="16" Background="#9E9E9E">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M9.4,10.5 L7,10.5 L7,7 L9.4,7 L11.5,4.5 L16.5,4.5 L18.6,7 L21,7 C22.1,7 23,7.9 23,9 L23,19 C23,20.1 22.1,21 21,21 L5,21 C3.9,21 3,20.1 3,19 L3,9 C3,7.9 3.9,7 5,7 L7.6,7 L9.4,10.5 Z M14,18 C16.76,18 19,15.76 19,13 C19,10.24 16.76,8 14,8 C11.24,8 9,10.24 9,13 C9,15.76 11.24,18 14,18 Z M14,16 C12.34,16 11,14.66 11,13 C11,11.34 12.34,10 14,10 C15.66,10 17,11.34 17,13 C17,14.66 15.66,16 14,16 Z" Fill="White"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="相机" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- 相册 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="56" Height="56" CornerRadius="16" Background="#E91E63">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M21,19 L21,5 C21,3.9 20.1,3 19,3 L5,3 C3.9,3 3,3.9 3,5 L3,19 C3,20.1 3.9,21 5,21 L19,21 C20.1,21 21,20.1 21,19 Z M8.5,13.5 L11,16.51 L14.5,12 L19,18 L5,18 L8.5,13.5 Z" Fill="White"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="相册" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
            </UniformGrid>

            <!-- 第二行应用 -->
            <UniformGrid Grid.Row="1" Columns="5" Margin="0,20">
                <!-- 设置 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Button Width="56" 
                            Height="56" 
                            CornerRadius="16" 
                            Background="#757575"
                            BorderThickness="0"
                            Click="OnSettingsButtonClick">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M19.14,12.94 C19.19,12.64 19.22,12.33 19.22,12 C19.22,11.68 19.19,11.36 19.14,11.06 L21.54,9.21 C21.74,9.05 21.8,8.77 21.68,8.55 L19.42,4.73 C19.3,4.51 19.03,4.43 18.81,4.52 L16.01,5.69 C15.51,5.3 14.97,4.97 14.39,4.72 L13.96,1.77 C13.92,1.53 13.71,1.36 13.46,1.36 L9.04,1.36 C8.79,1.36 8.58,1.53 8.54,1.77 L8.11,4.72 C7.53,4.97 6.99,5.3 6.49,5.69 L3.69,4.52 C3.46,4.43 3.19,4.51 3.07,4.73 L0.81,8.55 C0.69,8.77 0.75,9.05 0.95,9.21 L3.35,11.06 C3.3,11.36 3.27,11.68 3.27,12 C3.27,12.33 3.3,12.64 3.35,12.94 L0.95,14.79 C0.75,14.95 0.69,15.23 0.81,15.45 L3.07,19.27 C3.19,19.49 3.46,19.57 3.69,19.48 L6.49,18.31 C6.99,18.7 7.53,19.03 8.11,19.28 L8.54,22.23 C8.58,22.47 8.79,22.64 9.04,22.64 L13.46,22.64 C13.71,22.64 13.92,22.47 13.96,22.23 L14.39,19.28 C14.97,19.03 15.51,18.7 16.01,18.31 L18.81,19.48 C19.03,19.57 19.3,19.49 19.42,19.27 L21.68,15.45 C21.8,15.23 21.74,14.95 21.54,14.79 L19.14,12.94 Z M11.25,15.5 C9.46,15.5 8,14.04 8,12.25 C8,10.46 9.46,9 11.25,9 C13.04,9 14.5,10.46 14.5,12.25 C14.5,14.04 13.04,15.5 11.25,15.5 Z" Fill="White"/>
                        </Viewbox>
                    </Button>
                    <TextBlock Text="设置" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- 日历 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="56" Height="56" CornerRadius="16" Background="#FF9800">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M19,4 L18,4 L18,2 L16,2 L16,4 L8,4 L8,2 L6,2 L6,4 L5,4 C3.89,4 3.01,4.9 3.01,6 L3,20 C3,21.1 3.89,22 5,22 L19,22 C20.1,22 21,21.1 21,20 L21,6 C21,4.9 20.1,4 19,4 Z M19,20 L5,20 L5,9 L19,9 L19,20 Z" Fill="White"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="日历" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- 邮件 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="56" Height="56" CornerRadius="16" Background="#EA4335">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M20,4 L4,4 C2.9,4 2.01,4.9 2.01,6 L2,18 C2,19.1 2.9,20 4,20 L20,20 C21.1,20 22,19.1 22,18 L22,6 C22,4.9 21.1,4 20,4 Z M20,8 L12,13 L4,8 L4,6 L12,11 L20,6 L20,8 Z" Fill="White"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Gmail" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- 地图 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="56" Height="56" CornerRadius="16" Background="#4CAF50">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M20.5,3 L20.34,3.03 L15,5.1 L9,3 L3.36,4.9 C3.15,4.97 3,5.15 3,5.38 L3,20.5 C3,20.78 3.22,21 3.5,21 L3.66,20.97 L9,18.9 L15,21 L20.64,19.1 C20.85,19.03 21,18.85 21,18.62 L21,3.5 C21,3.22 20.78,3 20.5,3 Z M15,19 L9,16.89 L9,5 L15,7.11 L15,19 Z" Fill="White"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="地图" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- YouTube -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="56" Height="56" CornerRadius="16" Background="#FF0000">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M21.58,7.16 C21.58,7.16 21.35,5.62 20.68,4.95 C19.85,4.1 18.92,4.06 18.5,4.01 C15.53,3.8 12,3.8 12,3.8 C12,3.8 8.47,3.8 5.5,4.01 C5.08,4.06 4.15,4.1 3.32,4.95 C2.65,5.62 2.42,7.16 2.42,7.16 C2.42,7.16 2.19,8.96 2.19,10.76 L2.19,12.44 C2.19,14.24 2.42,16.04 2.42,16.04 C2.42,16.04 2.65,17.58 3.32,18.25 C4.15,19.1 5.23,19.07 5.72,19.15 C7.5,19.31 12,19.36 12,19.36 C12,19.36 15.53,19.36 18.5,19.15 C18.92,19.1 19.85,19.06 20.68,18.21 C21.35,17.54 21.58,16 21.58,16 C21.58,16 21.81,14.2 21.81,12.4 L21.81,10.72 C21.81,8.96 21.58,7.16 21.58,7.16 Z M9.95,14.5 L9.95,8.46 L15.32,11.5 L9.95,14.5 Z" Fill="White"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="YouTube" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
            </UniformGrid>

            <!-- 第三行应用 -->
            <UniformGrid Grid.Row="2" Columns="5" Margin="0,20">
                <!-- Play商店 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="56" Height="56" CornerRadius="16" Background="#01875F">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M3,20.5 L3,3.5 C3,2.91 3.34,2.39 3.84,2.15 L13.69,12 L3.84,21.85 C3.34,21.6 3,21.09 3,20.5 Z M16.81,15.12 L6.05,21.34 L14.54,12.85 L16.81,15.12 Z M20.16,10.81 C20.5,11.08 20.71,11.5 20.71,11.97 C20.71,12.44 20.5,12.86 20.16,13.13 L17.89,14.47 L15.39,12 L17.89,9.53 L20.16,10.81 Z M6.05,2.66 L16.81,8.88 L14.54,11.15 L6.05,2.66 Z" Fill="White"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="Play商店" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- 音乐 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="56" Height="56" CornerRadius="16" Background="#F44336">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M12,3 L12,13.55 C11.41,13.21 10.73,13 10,13 C7.79,13 6,14.79 6,17 C6,19.21 7.79,21 10,21 C12.21,21 14,19.21 14,17 L14,7 L18,7 L18,3 L12,3 Z" Fill="White"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="音乐" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- 视频 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="56" Height="56" CornerRadius="16" Background="#9C27B0">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M17,10.5 L17,7 C17,6.45 16.55,6 16,6 L4,6 C3.45,6 3,6.45 3,7 L3,17 C3,17.55 3.45,18 4,18 L16,18 C16.55,18 17,17.55 17,17 L17,13.5 L21,17.5 L21,6.5 L17,10.5 Z" Fill="White"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="视频" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- 备忘录 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="56" Height="56" CornerRadius="16" Background="#FF9800">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M14,2 L6,2 C4.9,2 4,2.9 4,4 L4,20 C4,21.1 4.9,22 6,22 L18,22 C19.1,22 20,21.1 20,20 L20,8 L14,2 Z M16,18 L8,18 L8,16 L16,16 L16,18 Z M16,14 L8,14 L8,12 L16,12 L16,14 Z M13,9 L13,3.5 L18.5,9 L13,9 Z" Fill="White"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="备忘录" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- 健康 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="56" Height="56" CornerRadius="16" Background="#E91E63">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M12,21.35 L10.55,20.03 C5.4,15.36 2,12.27 2,8.5 C2,5.41 4.42,3 7.5,3 C9.24,3 10.91,3.81 12,5.08 C13.09,3.81 14.76,3 16.5,3 C19.58,3 22,5.41 22,8.5 C22,12.27 18.6,15.36 13.45,20.03 L12,21.35 Z" Fill="White"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="健康" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
            </UniformGrid>

            <!-- 第四行应用 -->
            <UniformGrid Grid.Row="3" Columns="5" Margin="0,20">
                <!-- 钱包 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
                    <Border Width="56" Height="56" CornerRadius="16" Background="#4CAF50">
                        <Viewbox Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Path Data="M21,18 L21,19 C21,20.1 20.1,21 19,21 L5,21 C3.9,21 3,20.1 3,19 L3,6 C3,4.9 3.9,4 5,4 L19,4 C20.1,4 21,4.9 21,6 L21,7 L12,7 C10.9,7 10,7.9 10,9 L10,16 C10,17.1 10.9,18 12,18 L21,18 Z M12,16 L22,16 L22,9 L12,9 L12,16 Z M16,13.5 C15.17,13.5 14.5,12.83 14.5,12 C14.5,11.17 15.17,10.5 16,10.5 C16.83,10.5 17.5,11.17 17.5,12 C17.5,12.83 16.83,13.5 16,13.5 Z" Fill="White"/>
                        </Viewbox>
                    </Border>
                    <TextBlock Text="钱包" Foreground="White" FontSize="12" HorizontalAlignment="Center"/>
                </StackPanel>
                <!-- 翻译 -->
                <StackPanel HorizontalAlignment="Center" Spacing="8">
