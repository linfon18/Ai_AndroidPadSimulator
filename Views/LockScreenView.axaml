<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AndroidPadSimulator.ViewModels"
             x:Class="AndroidPadSimulator.Views.LockScreenView"
             x:DataType="vm:LockScreenViewModel">

    <Grid x:Name="RootGrid">
        <!-- 背景 -->
        <Image Source="{Binding WallpaperSource}"
               Stretch="UniformToFill"/>

        <!-- 渐变遮罩 - 顶部暗化 -->
        <Rectangle VerticalAlignment="Top" Height="200">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Offset="0" Color="#80000000"/>
                    <GradientStop Offset="1" Color="#00000000"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- 渐变遮罩 - 底部暗化 -->
        <Rectangle VerticalAlignment="Bottom" Height="300">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0%,0%" EndPoint="0%,100%">
                    <GradientStop Offset="0" Color="#00000000"/>
                    <GradientStop Offset="1" Color="#90000000"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- 顶部状态栏 -->
        <Grid VerticalAlignment="Top" Margin="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 时间 -->
            <TextBlock Text="{Binding CurrentTime}"
                       Foreground="White"
                       FontSize="14"
                       FontWeight="SemiBold"/>

            <!-- 状态图标 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                <Path Data="M2,18 L6,18 L6,22 L2,22 Z M7,16 L11,16 L11,22 L7,22 Z M12,12 L16,12 L16,22 L12,22 Z M17,8 L21,8 L21,22 L17,22 Z"
                      Fill="White" Width="16" Height="16"/>
                <Path Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 Z M12,20 C7.59,20 4,16.41 4,12 C4,7.59 7.59,4 12,4 C16.41,4 20,7.59 20,12 C20,16.41 16.41,20 12,20 Z M12,6 C9.79,6 8,7.79 8,10 L10,10 C10,8.9 10.9,8 12,8 C13.1,8 14,8.9 14,10 L16,10 C16,7.79 14.21,6 12,6 Z"
                      Fill="White" Width="16" Height="16"/>
            </StackPanel>
        </Grid>

        <!-- 中间时间和日期区域 -->
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Top" Margin="0,120,0,0" Spacing="4">
            <TextBlock x:Name="TimeTextBlock"
                       Text="{Binding CurrentTimeLarge}"
                       Foreground="White"
                       FontSize="88"
                       FontWeight="Light"
                       HorizontalAlignment="Center"/>

            <TextBlock Text="{Binding CurrentDate}"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="Normal"
                       Opacity="0.95"
                       HorizontalAlignment="Center"/>
        </StackPanel>

        <!-- 通知区域 -->
        <StackPanel VerticalAlignment="Center" Margin="40,80,40,0" Spacing="8">
            <!-- 模拟通知卡片 -->
            <Border Background="#CCFFFFFF" 
                    CornerRadius="16" 
                    Padding="16,12"
                    Opacity="0.9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="40" Height="40" CornerRadius="8" Background="#FF5722" Grid.Column="0">
                        <Path Data="M20,4 L4,4 C2.9,4 2.01,4.9 2.01,6 L2,18 C2,19.1 2.9,20 4,20 L20,20 C21.1,20 22,19.1 22,18 L22,6 C22,4.9 21.1,4 20,4 Z M20,8 L12,13 L4,8 L4,6 L12,11 L20,6 L20,8 Z"
                              Fill="White" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="Gmail" FontSize="13" FontWeight="SemiBold" Foreground="#333"/>
                        <TextBlock Text="新邮件 - 工作周报" FontSize="14" Foreground="#666" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="10:30" FontSize="12" Foreground="#999" VerticalAlignment="Top"/>
                </Grid>
            </Border>

            <Border Background="#CCFFFFFF" 
                    CornerRadius="16" 
                    Padding="16,12"
                    Opacity="0.9">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="40" Height="40" CornerRadius="8" Background="#4CAF50" Grid.Column="0">
                        <Path Data="M6.62,10.79 C8.06,13.62 10.38,15.94 13.21,17.38 L15.41,15.18 C15.69,14.9 16.08,14.82 16.43,14.93 C17.55,15.3 18.75,15.5 20,15.5 C20.55,15.5 21,15.95 21,16.5 L21,20 C21,20.55 20.55,21 20,21 C10.61,21 3,13.39 3,4 C3,3.45 3.45,3 4,3 L7.5,3 C8.05,3 8.5,3.45 8.5,4 C8.5,5.25 8.7,6.45 9.07,7.57 C9.18,7.92 9.1,8.31 8.82,8.59 L6.62,10.79 Z"
                              Fill="White" Width="24" Height="24" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" Margin="12,0,0,0">
                        <TextBlock Text="电话" FontSize="13" FontWeight="SemiBold" Foreground="#333"/>
                        <TextBlock Text="未接来电 (2)" FontSize="14" Foreground="#666" TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                    <TextBlock Grid.Column="2" Text="09:15" FontSize="12" Foreground="#999" VerticalAlignment="Top"/>
                </Grid>
            </Border>
        </StackPanel>

        <!-- 底部操作区域 - 可滑动解锁 -->
        <Grid VerticalAlignment="Bottom" Margin="0,0,0,32">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- 快捷按钮行 -->
            <Grid Grid.Row="0" Margin="32,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 左下角相机按钮 -->
                <Button Grid.Column="0"
                        Background="#40FFFFFF"
                        BorderThickness="0"
                        Width="48"
                        Height="48"
                        CornerRadius="24"
                        Command="{Binding OpenCameraCommand}"
                        HorizontalAlignment="Left">
                    <Path Data="M9.4,10.5 L7,10.5 L7,7 L9.4,7 L11.5,4.5 L16.5,4.5 L18.6,7 L21,7 C22.1,7 23,7.9 23,9 L23,19 C23,20.1 22.1,21 21,21 L5,21 C3.9,21 3,20.1 3,19 L3,9 C3,7.9 3.9,7 5,7 L7.6,7 L9.4,10.5 Z M14,18 C16.76,18 19,15.76 19,13 C19,10.24 16.76,8 14,8 C11.24,8 9,10.24 9,13 C9,15.76 11.24,18 14,18 Z M14,16 C12.34,16 11,14.66 11,13 C11,11.34 12.34,10 14,10 C15.66,10 17,11.34 17,13 C17,14.66 15.66,16 14,16 Z"
                          Fill="White" Width="24" Height="24"/>
                </Button>

                <!-- 右下角手电筒按钮 -->
                <Button Grid.Column="2"
                        Background="#40FFFFFF"
                        BorderThickness="0"
                        Width="48"
                        Height="48"
                        CornerRadius="24"
                        HorizontalAlignment="Right">
                    <Path Data="M6,2 L18,2 L16,8 L20,8 L14,22 L14,12 L10,12 L10,22 L4,8 L8,8 L6,2 Z"
                          Fill="White" Width="24" Height="24"/>
                </Button>
            </Grid>

            <!-- 解锁提示区域 - 添加滑动检测 -->
            <Border Grid.Row="1" 
                    Margin="0,24,0,0"
                    Background="Transparent"
                    x:Name="UnlockArea"
                    PointerPressed="OnUnlockAreaPressed"
                    PointerMoved="OnUnlockAreaMoved"
                    PointerReleased="OnUnlockAreaReleased">
                <StackPanel HorizontalAlignment="Center" Spacing="12">
                    <!-- 解锁图标 -->
                    <Border Width="56"
                            Height="56"
                            CornerRadius="28"
                            Background="#50FFFFFF"
                            x:Name="UnlockIcon">
                        <Path Data="M12,17 C13.1,17 14,16.1 14,15 C14,13.9 13.1,13 12,13 C10.9,13 10,13.9 10,15 C10,16.1 10.9,17 12,17 Z M18,8 L17,8 L17,6 C17,3.24 14.76,1 12,1 C9.24,1 7,3.24 7,6 L7,8 L6,8 C4.9,8 4,8.9 4,10 L4,20 C4,21.1 4.9,22 6,22 L18,22 C19.1,22 20,21.1 20,20 L20,10 C20,8.9 19.1,8 18,8 Z M12,19 C9.79,19 8,17.21 8,15 C8,12.79 9.79,11 12,11 C14.21,11 16,12.79 16,15 C16,17.21 14.21,19 12,19 Z M9.5,8 L9.5,6 C9.5,4.62 10.62,3.5 12,3.5 C13.38,3.5 14.5,4.62 14.5,6 L14.5,8 L9.5,8 Z"
                              Fill="White" Width="28" Height="28" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>

                    <!-- 解锁提示文字 -->
                    <TextBlock Text="向上滑动解锁"
                               Foreground="White"
                               FontSize="15"
                               FontWeight="Medium"
                               Opacity="0.9"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- 相机界面覆盖层 -->
        <Grid IsVisible="{Binding IsCameraOpen}"
              Background="#000000">

            <!-- 相机预览区域（模拟） -->
            <Grid Background="#0d0d0d">
                <!-- 取景框 -->
                <Border Margin="20,40" Background="#1a1a1a">
                    <Grid>
                        <!-- 网格线 -->
                        <Grid Opacity="0.4">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="*"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Row="0" Grid.Column="0" BorderBrush="White" BorderThickness="0,0,1,1"/>
                            <Border Grid.Row="0" Grid.Column="1" BorderBrush="White" BorderThickness="1,0,1,1"/>
                            <Border Grid.Row="0" Grid.Column="2" BorderBrush="White" BorderThickness="1,0,0,1"/>
                            <Border Grid.Row="1" Grid.Column="0" BorderBrush="White" BorderThickness="0,1,1,1"/>
                            <Border Grid.Row="1" Grid.Column="1" BorderBrush="White" BorderThickness="1,1,1,1"/>
                            <Border Grid.Row="1" Grid.Column="2" BorderBrush="White" BorderThickness="1,1,0,1"/>
                            <Border Grid.Row="2" Grid.Column="0" BorderBrush="White" BorderThickness="0,1,1,0"/>
                            <Border Grid.Row="2" Grid.Column="1" BorderBrush="White" BorderThickness="1,1,1,0"/>
                            <Border Grid.Row="2" Grid.Column="2" BorderBrush="White" BorderThickness="1,1,0,0"/>
                        </Grid>
                        
                        <!-- 对焦框 -->
                        <Border Width="80" Height="80" BorderBrush="#4CAF50" BorderThickness="2" HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Grid>
                                <Rectangle Width="10" Height="2" Fill="#4CAF50" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-1,-1,0,0"/>
                                <Rectangle Width="10" Height="2" Fill="#4CAF50" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-1,-1,0"/>
                                <Rectangle Width="10" Height="2" Fill="#4CAF50" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-1,0,0,-1"/>
                                <Rectangle Width="10" Height="2" Fill="#4CAF50" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-1,-1"/>
                                <Rectangle Width="2" Height="10" Fill="#4CAF50" HorizontalAlignment="Left" VerticalAlignment="Top" Margin="-1,-1,0,0"/>
                                <Rectangle Width="2" Height="10" Fill="#4CAF50" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="0,-1,-1,0"/>
                                <Rectangle Width="2" Height="10" Fill="#4CAF50" HorizontalAlignment="Left" VerticalAlignment="Bottom" Margin="-1,0,0,-1"/>
                                <Rectangle Width="2" Height="10" Fill="#4CAF50" HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="0,0,-1,-1"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Border>
            </Grid>

            <!-- 相机顶部栏 -->
            <Grid VerticalAlignment="Top" Margin="20,16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding CloseCameraCommand}">
                    <Path Data="M19,6.41 L17.59,5 L12,10.59 L6.41,5 L5,6.41 L10.59,12 L5,17.59 L6.41,19 L12,13.41 L17.59,19 L19,17.59 L13.41,12 Z"
                          Fill="White" Width="28" Height="28"/>
                </Button>

                <StackPanel Grid.Column="1" HorizontalAlignment="Center" Orientation="Horizontal" Spacing="16">
                    <Path Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 Z M12,20 C7.59,20 4,16.41 4,12 C4,7.59 7.59,4 12,4 C16.41,4 20,7.59 20,12 C20,16.41 16.41,20 12,20 Z M12,6 C9.79,6 8,7.79 8,10 L10,10 C10,8.9 10.9,8 12,8 C13.1,8 14,8.9 14,10 L16,10 C16,7.79 14.21,6 12,6 Z"
                          Fill="White" Width="24" Height="24"/>
                    <Path Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 Z M12,20 C7.59,20 4,16.41 4,12 C4,7.59 7.59,4 12,4 C16.41,4 20,7.59 20,12 C20,16.41 16.41,20 12,20 Z"
                          Fill="White" Width="24" Height="24"/>
                </StackPanel>

                <Path Grid.Column="2" Data="M12,8 L12,14 L16.5,17.5 L15.08,19.42 L10,15 L10,8 L12,8 Z M12,2 C6.5,2 2,6.5 2,12 C2,17.5 6.5,22 12,22 C17.5,22 22,17.5 22,12 C22,6.5 17.5,2 12,2 Z M12,20 C7.59,20 4,16.41 4,12 C4,7.59 7.59,4 12,4 C16.41,4 20,7.59 20,12 C20,16.41 16.41,20 12,20 Z"
                      Fill="White" Width="24" Height="24"/>
            </Grid>

            <!-- 相机底部控制栏 -->
            <Grid VerticalAlignment="Bottom" Margin="0,0,0,32">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 相册缩略图 -->
                <Border Grid.Column="0" 
                        Width="48" 
                        Height="48" 
                        CornerRadius="8" 
                        Background="#333"
                        HorizontalAlignment="Center"
                        BorderBrush="White" 
                        BorderThickness="2"/>

                <!-- 拍照按钮 -->
                <Border Grid.Column="1" 
                        Width="72" 
                        Height="72" 
                        CornerRadius="36" 
                        Background="White"
                        HorizontalAlignment="Center">
                    <Border Width="64" 
                            Height="64" 
                            CornerRadius="32" 
                            Background="White"
                            BorderBrush="#333" 
                            BorderThickness="3"/>
                </Border>

                <!-- 切换摄像头 -->
                <Button Grid.Column="2"
                        Background="Transparent"
                        BorderThickness="0"
                        HorizontalAlignment="Center">
                    <Path Data="M20,5 L4,5 C2.9,5 2,5.9 2,7 L2,17 C2,18.1 2.9,19 4,19 L20,19 C21.1,19 22,18.1 22,17 L22,7 C22,5.9 21.1,5 20,5 Z M16.5,16 L15.21,14.71 C15.67,14.24 16,13.65 16,13 C16,11.34 14.66,10 13,10 C12.35,10 11.76,10.33 11.29,10.79 L9.91,9.41 C10.58,8.54 11.71,8 13,8 C15.76,8 18,10.24 18,13 C18,14.29 17.46,15.42 16.59,16.09 L16.5,16 Z M6,13 C6,11.71 6.54,10.58 7.41,9.91 L7.5,10 L8.79,11.29 C8.33,11.76 8,12.35 8,13 C8,14.66 9.34,16 11,16 C11.65,16 12.24,15.67 12.71,15.21 L14.09,16.59 C13.42,17.46 12.29,18 11,18 C8.24,18 6,15.76 6,13 Z"
                          Fill="White" Width="32" Height="32"/>
                </Button>
            </Grid>

            <!-- 拍照模式选择 -->
            <StackPanel VerticalAlignment="Bottom" Margin="0,0,0,120" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="24">
                <TextBlock Text="视频" Foreground="#B3FFFFFF" FontSize="14"/>
                <TextBlock Text="照片" Foreground="White" FontSize="16" FontWeight="Bold"/>
                <TextBlock Text="人像" Foreground="#B3FFFFFF" FontSize="14"/>
                <TextBlock Text="夜景" Foreground="#B3FFFFFF" FontSize="14"/>
                <TextBlock Text="更多" Foreground="#B3FFFFFF" FontSize="14"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
