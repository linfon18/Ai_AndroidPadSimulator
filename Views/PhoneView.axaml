<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AndroidPadSimulator.ViewModels"
             x:Class="AndroidPadSimulator.Views.PhoneView"
             x:DataType="vm:PhoneViewModel">

    <Grid Background="#FF121212">
        <!-- 顶部状态栏 -->
        <Grid VerticalAlignment="Top" Margin="24,16,24,0" Height="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 返回按钮 -->
            <Button Grid.Column="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Width="40"
                    Height="40"
                    Command="{Binding GoBackCommand}">
                <Path Data="M20,11 L7.83,11 L13.42,5.41 L12,4 L4,12 L12,20 L13.41,18.59 L7.83,13 L20,13 L20,11 Z"
                      Fill="White" Width="24" Height="24"/>
            </Button>

            <!-- 标题 -->
            <TextBlock Grid.Column="1"
                       Text="电话"
                       Foreground="White"
                       FontSize="18"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- 状态图标 -->
            <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10">
                <Path Data="M2,18 L6,18 L6,22 L2,22 Z M7,16 L11,16 L11,22 L7,22 Z M12,12 L16,12 L16,22 L12,22 Z M17,8 L21,8 L21,22 L17,22 Z"
                      Fill="White" Width="16" Height="16"/>
                <Path Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 Z M12,20 C7.59,20 4,16.41 4,12 C4,7.59 7.59,4 12,4 C16.41,4 20,7.59 20,12 C20,16.41 16.41,20 12,20 Z M12,6 C9.79,6 8,7.79 8,10 L10,10 C10,8.9 10.9,8 12,8 C13.1,8 14,8.9 14,10 L16,10 C16,7.79 14.21,6 12,6 Z"
                      Fill="White" Width="16" Height="16"/>
            </StackPanel>
        </Grid>

        <!-- 内容区域 -->
        <Grid Margin="0,72,0,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Tab内容 -->
            <Grid Grid.Row="0">
                <!-- 拨号盘 -->
                <Grid IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <!-- 号码显示 -->
                    <TextBlock Grid.Row="0"
                               Text="{Binding PhoneNumber}"
                               Foreground="White"
                               FontSize="36"
                               HorizontalAlignment="Center"
                               Margin="0,40,0,20"/>

                    <!-- 数字键盘 -->
                    <UniformGrid Grid.Row="1" Columns="3" Margin="40,0">
                        <Button Background="Transparent" 
                                BorderThickness="0"
                                Command="{Binding AppendNumberCommand}"
                                CommandParameter="1">
                            <TextBlock Text="1" Foreground="White" FontSize="32" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Background="Transparent" 
                                BorderThickness="0"
                                Command="{Binding AppendNumberCommand}"
                                CommandParameter="2">
                            <TextBlock Text="2" Foreground="White" FontSize="32" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Background="Transparent" 
                                BorderThickness="0"
                                Command="{Binding AppendNumberCommand}"
                                CommandParameter="3">
                            <TextBlock Text="3" Foreground="White" FontSize="32" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Background="Transparent" 
                                BorderThickness="0"
                                Command="{Binding AppendNumberCommand}"
                                CommandParameter="4">
                            <TextBlock Text="4" Foreground="White" FontSize="32" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Background="Transparent" 
                                BorderThickness="0"
                                Command="{Binding AppendNumberCommand}"
                                CommandParameter="5">
                            <TextBlock Text="5" Foreground="White" FontSize="32" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Background="Transparent" 
                                BorderThickness="0"
                                Command="{Binding AppendNumberCommand}"
                                CommandParameter="6">
                            <TextBlock Text="6" Foreground="White" FontSize="32" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Background="Transparent" 
                                BorderThickness="0"
                                Command="{Binding AppendNumberCommand}"
                                CommandParameter="7">
                            <TextBlock Text="7" Foreground="White" FontSize="32" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Background="Transparent" 
                                BorderThickness="0"
                                Command="{Binding AppendNumberCommand}"
                                CommandParameter="8">
                            <TextBlock Text="8" Foreground="White" FontSize="32" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Background="Transparent" 
                                BorderThickness="0"
                                Command="{Binding AppendNumberCommand}"
                                CommandParameter="9">
                            <TextBlock Text="9" Foreground="White" FontSize="32" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Background="Transparent" 
                                BorderThickness="0"
                                Command="{Binding AppendNumberCommand}"
                                CommandParameter="*">
                            <TextBlock Text="*" Foreground="White" FontSize="32" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Background="Transparent" 
                                BorderThickness="0"
                                Command="{Binding AppendNumberCommand}"
                                CommandParameter="0">
                            <TextBlock Text="0" Foreground="White" FontSize="32" HorizontalAlignment="Center"/>
                        </Button>
                        <Button Background="Transparent" 
                                BorderThickness="0"
                                Command="{Binding AppendNumberCommand}"
                                CommandParameter="#">
                            <TextBlock Text="#" Foreground="White" FontSize="32" HorizontalAlignment="Center"/>
                        </Button>
                    </UniformGrid>

                    <!-- 拨打和删除按钮 -->
                    <Grid Grid.Row="2" Margin="40,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="1"
                                Width="72"
                                Height="72"
                                CornerRadius="36"
                                Background="#4CAF50"
                                Command="{Binding CallCommand}">
                            <Path Data="M6.62,10.79 C8.06,13.62 10.38,15.94 13.21,17.38 L15.41,15.18 C15.69,14.9 16.08,14.82 16.43,14.93 C17.55,15.3 18.75,15.5 20,15.5 C20.55,15.5 21,15.95 21,16.5 L21,20 C21,20.55 20.55,21 20,21 C10.61,21 3,13.39 3,4 C3,3.45 3.45,3 4,3 L7.5,3 C8.05,3 8.5,3.45 8.5,4 C8.5,5.25 8.7,6.45 9.07,7.57 C9.18,7.92 9.1,8.31 8.82,8.59 L6.62,10.79 Z"
                                  Fill="White" Width="32" Height="32"/>
                        </Button>

                        <Button Grid.Column="2"
                                Background="Transparent"
                                BorderThickness="0"
                                Command="{Binding DeleteNumberCommand}">
                            <Path Data="M22,3 L7,3 C6.31,3 5.77,3.35 5.41,3.88 L0,12 L5.41,20.11 C5.77,20.64 6.31,21 7,21 L22,21 C23.1,21 24,20.1 24,19 L24,5 C24,3.9 23.1,3 22,3 Z M19,15.59 L17.59,17 L14,13.41 L10.41,17 L9,15.59 L12.59,12 L9,8.41 L10.41,7 L14,10.59 L17.59,7 L19,8.41 L15.41,12 L19,15.59 Z"
                                  Fill="#B3FFFFFF" Width="24" Height="24"/>
                        </Button>
                    </Grid>
                </Grid>

                <!-- 通话记录 -->
                <ScrollViewer IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1}"
                              Margin="24,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="通话记录" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,16,0,8"/>
                        <ItemsControl ItemsSource="{Binding CallLogs}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="#1E1E1E" 
                                            CornerRadius="12"
                                            Padding="16,12"
                                            Margin="0,4"
                                            BorderThickness="0"
                                            HorizontalAlignment="Stretch">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 通话类型图标 -->
                                            <Border Grid.Column="0" 
                                                    Width="40" 
                                                    Height="40" 
                                                    CornerRadius="20"
                                                    Background="{Binding Type, Converter={StaticResource CallTypeToColorConverter}}">
                                                <Path Data="M6.62,10.79 C8.06,13.62 10.38,15.94 13.21,17.38 L15.41,15.18 C15.69,14.9 16.08,14.82 16.43,14.93 C17.55,15.3 18.75,15.5 20,15.5 C20.55,15.5 21,15.95 21,16.5 L21,20 C21,20.55 20.55,21 20,21 C10.61,21 3,13.39 3,4 C3,3.45 3.45,3 4,3 L7.5,3 C8.05,3 8.5,3.45 8.5,4 C8.5,5.25 8.7,6.45 9.07,7.57 C9.18,7.92 9.1,8.31 8.82,8.59 L6.62,10.79 Z"
                                                      Fill="White" Width="20" Height="20"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16"/>
                                                <TextBlock Text="{Binding Number}" Foreground="#B3FFFFFF" FontSize="14" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <StackPanel Grid.Column="2" HorizontalAlignment="Right">
                                                <TextBlock Text="{Binding Time}" Foreground="#80FFFFFF" FontSize="12"/>
                                                <TextBlock Text="{Binding Duration}" Foreground="#80FFFFFF" FontSize="12" Margin="0,4,0,0"/>
                                            </StackPanel>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>

                <!-- 联系人 -->
                <ScrollViewer IsVisible="{Binding SelectedTabIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2}"
                              Margin="24,0">
                    <StackPanel Spacing="8">
                        <TextBlock Text="联系人" Foreground="White" FontSize="20" FontWeight="SemiBold" Margin="0,16,0,8"/>
                        <ItemsControl ItemsSource="{Binding Contacts}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Button Background="#1E1E1E" 
                                            CornerRadius="12"
                                            Padding="16,12"
                                            Margin="0,4"
                                            BorderThickness="0"
                                            HorizontalAlignment="Stretch"
                                            Command="{Binding $parent[UserControl].DataContext.SelectContactCommand}"
                                            CommandParameter="{Binding}">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- 头像 -->
                                            <Border Grid.Column="0" 
                                                    Width="48" 
                                                    Height="48" 
                                                    CornerRadius="24"
                                                    Background="{Binding AvatarColor}">
                                                <TextBlock Text="{Binding Name, Converter={StaticResource FirstCharConverter}}"
                                                           Foreground="White"
                                                           FontSize="20"
                                                           FontWeight="SemiBold"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center"/>
                                            </Border>

                                            <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}" Foreground="White" FontSize="16"/>
                                                <TextBlock Text="{Binding Number}" Foreground="#B3FFFFFF" FontSize="14" Margin="0,2,0,0"/>
                                            </StackPanel>

                                            <Path Grid.Column="2"
                                                  Data="M6.62,10.79 C8.06,13.62 10.38,15.94 13.21,17.38 L15.41,15.18 C15.69,14.9 16.08,14.82 16.43,14.93 C17.55,15.3 18.75,15.5 20,15.5 C20.55,15.5 21,15.95 21,16.5 L21,20 C21,20.55 20.55,21 20,21 C10.61,21 3,13.39 3,4 C3,3.45 3.45,3 4,3 L7.5,3 C8.05,3 8.5,3.45 8.5,4 C8.5,5.25 8.7,6.45 9.07,7.57 C9.18,7.92 9.1,8.31 8.82,8.59 L6.62,10.79 Z"
                                                  Fill="#4CAF50" Width="24" Height="24"/>
                                        </Grid>
                                    </Button>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>
                </ScrollViewer>
            </Grid>

            <!-- 底部Tab栏 -->
            <Grid Grid.Row="1" Background="#1E1E1E" Height="64">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding SetTabIndexCommand}"
                        CommandParameter="0">
                    <StackPanel HorizontalAlignment="Center">
                        <Path Data="M6.62,10.79 C8.06,13.62 10.38,15.94 13.21,17.38 L15.41,15.18 C15.69,14.9 16.08,14.82 16.43,14.93 C17.55,15.3 18.75,15.5 20,15.5 C20.55,15.5 21,15.95 21,16.5 L21,20 C21,20.55 20.55,21 20,21 C10.61,21 3,13.39 3,4 C3,3.45 3.45,3 4,3 L7.5,3 C8.05,3 8.5,3.45 8.5,4 C8.5,5.25 8.7,6.45 9.07,7.57 C9.18,7.92 9.1,8.31 8.82,8.59 L6.62,10.79 Z"
                              Fill="{Binding SelectedTabIndex, Converter={StaticResource TabIndexToColorConverter}, ConverterParameter=0}"
                              Width="24" Height="24"/>
                        <TextBlock Text="拨号" 
                                   Foreground="{Binding SelectedTabIndex, Converter={StaticResource TabIndexToColorConverter}, ConverterParameter=0}"
                                   FontSize="12"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="1"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding SetTabIndexCommand}"
                        CommandParameter="1">
                    <StackPanel HorizontalAlignment="Center">
                        <Path Data="M12,2 C6.48,2 2,6.48 2,12 C2,17.52 6.48,22 12,22 C17.52,22 22,17.52 22,12 C22,6.48 17.52,2 12,2 Z M12,20 C7.59,20 4,16.41 4,12 C4,7.59 7.59,4 12,4 C16.41,4 20,7.59 20,12 C20,16.41 16.41,20 12,20 Z M13,7 L11,7 L11,13 L16,16 L17,14.5 L13,11.5 L13,7 Z"
                              Fill="{Binding SelectedTabIndex, Converter={StaticResource TabIndexToColorConverter}, ConverterParameter=1}"
                              Width="24" Height="24"/>
                        <TextBlock Text="记录" 
                                   Foreground="{Binding SelectedTabIndex, Converter={StaticResource TabIndexToColorConverter}, ConverterParameter=1}"
                                   FontSize="12"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>

                <Button Grid.Column="2"
                        Background="Transparent"
                        BorderThickness="0"
                        Command="{Binding SetTabIndexCommand}"
                        CommandParameter="2">
                    <StackPanel HorizontalAlignment="Center">
                        <Path Data="M12,12 C14.21,12 16,10.21 16,8 C16,5.79 14.21,4 12,4 C9.79,4 8,5.79 8,8 C8,10.21 9.79,12 12,12 Z M12,14 C9.33,14 4,15.34 4,18 L4,20 L20,20 L20,18 C20,15.34 14.67,14 12,14 Z"
                              Fill="{Binding SelectedTabIndex, Converter={StaticResource TabIndexToColorConverter}, ConverterParameter=2}"
                              Width="24" Height="24"/>
                        <TextBlock Text="联系人" 
                                   Foreground="{Binding SelectedTabIndex, Converter={StaticResource TabIndexToColorConverter}, ConverterParameter=2}"
                                   FontSize="12"
                                   Margin="0,4,0,0"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Grid>
    </Grid>
</UserControl>
