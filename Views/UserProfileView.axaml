<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:AndroidPadSimulator.ViewModels"
             x:Class="AndroidPadSimulator.Views.UserProfileView"
             x:DataType="vm:UserProfileViewModel">

    <Grid Background="#FF121212">
        <!-- 顶部状态栏 -->
        <Grid VerticalAlignment="Top" Margin="24,16,24,0" Height="40">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 返回按钮 -->
            <Button Grid.Column="0"
                    Background="Transparent"
                    BorderThickness="0"
                    Width="40"
                    Height="40"
                    Command="{Binding GoBackCommand}">
                <TextBlock Text="&lt;" Foreground="White" FontSize="24"/>
            </Button>

            <!-- 标题 -->
            <TextBlock Grid.Column="1"
                       Text="个人资料"
                       Foreground="White"
                       FontSize="16"
                       FontWeight="SemiBold"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>

            <!-- 更多按钮 -->
            <Button Grid.Column="2"
                    Background="Transparent"
                    BorderThickness="0"
                    Width="40"
                    Height="40">
                <TextBlock Text="..." Foreground="White" FontSize="24"/>
            </Button>
        </Grid>

        <!-- 内容区域 -->
        <ScrollViewer Margin="0,72,0,0" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="24,0,24,24" Spacing="16">
                <!-- 用户头像和基本信息 -->
                <Border Background="#1E1E1E" 
                        CornerRadius="16" 
                        Padding="24" 
                        Margin="0,16,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <!-- 头像 -->
                        <Border Grid.Column="0" 
                                Width="80" 
                                Height="80" 
                                CornerRadius="40" 
                                Background="#4CAF50" 
                                Margin="0,0,20,0">
                            <TextBlock Text="{Binding ProfileImage}" 
                                       Foreground="White" 
                                       FontSize="36" 
                                       FontWeight="SemiBold"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- 用户信息 -->
                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding UserName}" 
                                       Foreground="White" 
                                       FontSize="20" 
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="{Binding Email}" 
                                       Foreground="#B3FFFFFF" 
                                       FontSize="14" 
                                       Margin="0,4,0,0"/>
                            <TextBlock Text="{Binding AccountType}" 
                                       Foreground="#80FFFFFF" 
                                       FontSize="12" 
                                       Margin="0,2,0,0"/>
                            <Button Background="Transparent" 
                                    BorderThickness="1" 
                                    BorderBrush="#4CAF50" 
                                    Foreground="#4CAF50" 
                                    FontSize="14" 
                                    Padding="12,6" 
                                    Margin="0,8,0,0"
                                    Width="120"
                                    Command="{Binding EditProfileCommand}">
                                编辑个人资料
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>